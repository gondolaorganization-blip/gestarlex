# ─── Base de datos ────────────────────────────────────────────────────────────
POSTGRES_USER=gestarlex
POSTGRES_PASSWORD=CAMBIAR_password_seguro
POSTGRES_DB=gestarlex_db
DATABASE_URL="postgresql://gestarlex:CAMBIAR_password_seguro@postgres:5432/gestarlex_db"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generar con: openssl rand -base64 64
JWT_SECRET=CAMBIAR_secreto_de_al_menos_64_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3099
NODE_ENV=production
FRONTEND_URL=https://gestarsoft.com

# ─── Archivos ─────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=25

# ─── Email ────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.tuproveedor.com
SMTP_PORT=587
SMTP_USER=noreply@gestarsoft.com
SMTP_PASS=CAMBIAR_password_smtp
EMAIL_FROM="GESTARLEX <noreply@gestarsoft.com>"

# ─── IA ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── PayPal ───────────────────────────────────────────────────────────────────
# Cambiar PAYPAL_MODE=live cuando estés listo para cobrar real
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_PLAN_ID_SOLO=
PAYPAL_PLAN_ID_FIRMA=
PAYPAL_PLAN_ID_ENTERPRISE=
