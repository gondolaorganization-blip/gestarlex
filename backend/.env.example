# Base de datos
DATABASE_URL="postgresql://gestarlex:gestarlex_pass@localhost:5432/gestarlex_db"

# JWT
JWT_SECRET="cambia_esto_por_un_secreto_seguro_de_al_menos_32_chars"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# Servidor
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Archivos
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=25

# Email (opcional — para notificaciones)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="GESTARLEX <noreply@gestarlex.com>"

# IA (opcional — para asistente legal)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
